{
  "collaboration_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "agent_buffer_font_size": 20.0,
  "agent_ui_font_size": 20.0,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "notification_panel": {
    "button": true,
    "dock": "right",
  },
  "debugger": {
    "dock": "right",
  },
  "terminal": {
    "working_directory": "current_file_directory",
    "dock": "right",
  },
  "inlay_hints": { "show_background": false, "enabled": true },
  "show_call_status_icon": false,
  "show_whitespaces": "none",
  "edit_predictions": {
    "provider": "zed",
  },
  "project_panel": {
    "dock": "right",
    "bold_folder_labels": true,
  },
  "git": {
    "blame": {
      "show_avatar": false,
    },
    "inline_blame": {
      "enabled": false,
    },
  },
  "hover_popover_enabled": false,
  "which_key": {
    "enabled": false,
  },
  "inline_code_actions": false,
  "relative_line_numbers": "disabled",
  "autosave": "on_focus_change",
  "show_wrap_guides": false,
  "rounded_selection": false,
  "unnecessary_code_fade": 0.3,
  "hide_mouse": "on_typing_and_movement",
  "cursor_shape": "bar",
  "buffer_line_height": "comfortable",
  "agent": {
    "notify_when_agent_waiting": "never",
    "dock": "right",
    "enable_feedback": false,
    "default_profile": "write",
    "default_model": {
      "provider": "lmstudio",
      "model": "apriel-1.6-15b-thinker-mlx",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "show_completions_on_input": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 20.0,
  "buffer_font_size": 20.0,
  "ui_font_family": "Iosevka Term Slab",
  "buffer_font_family": "Iosevka Term Slab",
  "buffer_font_weight": 500,
  "ui_font_weight": 500,
  "cursor_blink": false,
  "gutter": {
    "runnables": true,
    "line_numbers": false,
    "folds": false,
  },
  "buffer_font_features": {
    "calt": false,
  },
  "tab_bar": {
    "show": true,
  },
  "scrollbar": { "show": "never" },
  "indent_guides": {
    "enabled": false,
  },
  "ensure_final_newline_on_save": true,
  "minimap": { "show": "never" },
  "theme": {
    "mode": "dark",
    "light": "Modus Operandi Deuteranopia",
    "dark": "Modus Vivendi Deuteranopia",
  },
  "vim_mode": true,
}
